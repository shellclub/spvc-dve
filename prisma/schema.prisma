// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Department {
  id Int @id @default(autoincrement())
  depname String @unique 
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt() @map("update_at")
  teacher  Teacher[]
  marjors Major[]
  student Student[]
  @@map("departments")
}

model Major {
  id  Int @id @default(autoincrement())
  major_name String @unique
  department Department @relation(fields: [departmentId],references: [id])
  departmentId  Int
  students Student[]
  teacher Teacher[]
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt  @map("update_at")

}

model Login {
  id                Int   @id   @default(autoincrement())
  username          String  @unique
  password          String  @unique
  userId            Int     @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  password_status   Int     @default(0)
}
model Teacher {
  id             Int @id @default(autoincrement())
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  departmentId   Int?
  majorId        Int?
  major          Major? @relation(fields: [majorId], references: [id], onDelete: Cascade)
  room           String?
  educationId    Int?
  education      education_levels? @relation(fields: [educationId], references: [id], onDelete: Cascade)
  term           String?
  years          String?
  grade          String?
  userId         Int   @unique
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             Int              @id @default(autoincrement())
  firstname      String
  lastname       String
  citizenId      String     @db.VarChar(13)     @unique
  phone          String     @db.VarChar(10)     @unique
  role           Int        @default(6)
  sex            Int
  createdAt      DateTime         @default(now())
  student        Student?         // ถ้าเป็นนักศึกษา
  birthday       DateTime
  user_img       String?
  teacher        Teacher?
  login          Login?   
  @@map("users")
}



model Student {
  id             Int        @id @default(autoincrement())
  studentId      String    @unique
  user           User       @relation(fields: [userId], references: [id],onDelete: Cascade)
  userId         Int        @unique
  education      education_levels @relation(fields: [educationLevel], references: [id])
  educationLevel Int     // เช่น ปวช., ปวส., ป.ตรี
  companies      companies[]
  major_id      Int?
  major         Major?  @relation(fields: [major_id], references: [id], onDelete: Cascade)
  academicYear   String     // เช่น 2566
  status         Int @default(1)
  term           String
  room           String
  inturnship     Inturnship?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId   Int?
  report         InternshipReport[]
  gradeLevel     String?
  @@map("students")
}
model Inturnship{
  id Int @id() @default(autoincrement())
  student Student @relation(references: [id], fields: [studentId], onDelete: Cascade)
  studentId Int @unique
  selectedDays Json
  dayperweeks String
  create_at DateTime @default(now())
  @@map("inturnship")
}

model InternshipReport {
  id Int @id() @default(autoincrement())
  student Student @relation(references: [id], fields: [studentId], onDelete: Cascade)
  studentId Int 
  title String
  description String?
  reportDate DateTime
  image String
  @@map("internship_report")
  
}

model education_levels{
  id Int @id() @default(autoincrement())
  name String @unique
  create_at DateTime @default(now())
  student Student[]
  teacher Teacher[]
}

model companies {
  id Int @id @default(autoincrement())
  name String
  address String
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("companies")
}
